# .env.example — Copy this file to .env and fill in your values.
# NEVER commit .env to git. It is already in .gitignore.
#
# How to use:
#   cp .env.example .env
#   Edit .env with your actual sandbox URL and test credentials.

# ── Sandbox URL (get this from TripleTen each sprint) ────────────────────
URBAN_ROUTES_URL=https://cnt-YOUR-SANDBOX-ID.containerhub.tripleten-services.com

# ── Addresses ─────────────────────────────────────────────────────────────────────────────
TEST_FROM_ADDRESS=East 2nd Street, 601
TEST_TO_ADDRESS=1300 1st St

# ── Contact ──────────────────────────────────────────────────────────────────────────────
TEST_PHONE=+12025550199

# ── Payment (sandbox values only — never use real card data) ─────────────────────
TEST_CARD_NUMBER=1234 0000 5678
TEST_CARD_CVV=111

# ── SMS Code (TripleTen sandbox always uses 000000) ─────────────────────────────
TEST_SMS_CODE=000000

# ── Driver Message ──────────────────────────────────────────────────────────────────────
TEST_DRIVER_COMMENT=Bring a blanket

# ── Timeouts (seconds) ─────────────────────────────────────────────────────────────────
TIMEOUT_EXPLICIT=10
TIMEOUT_DRIVER_INFO=60

# ── Screenshots ──────────────────────────────────────────────────────────────────────
SCREENSHOTS_DIR=screenshots
